# ─────────────────────────────────────────────
# FinanceFlow — Production Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env.production and fill in
# the values for your deployment.
#
# cp .env.example .env.production
# ─────────────────────────────────────────────

# ── Application ──────────────────────────────
PORT=3000
NODE_ENV=production

# ── Database ─────────────────────────────────
# Postgres connection string for the app (uses `postgres` npm package)
# For Docker Compose deployment, use: postgres://postgres:postgres@db:5432/finance
DATABASE_URL=postgres://postgres:postgres@localhost:5432/finance

# ── Authentication (Better Auth) ─────────────
# Strong random string, at least 32 characters. Generate with:
#   openssl rand -hex 32
BETTER_AUTH_SECRET=

# Public URL of your app (must match browser-visible URL).
# With Cloudflare Tunnel: https://your-domain.com
BETTER_AUTH_URL=http://localhost:3000

# URL of the frontend (same as BETTER_AUTH_URL for same-origin deployment)
FRONTEND_URL=http://localhost:3000

# Comma-separated list of trusted origins
TRUSTED_ORIGINS=http://localhost:3000

# ── AI Insights (OpenRouter) ─────────────────
OPENROUTER_API_KEY=

# ── OAuth Providers (Optional) ───────────────
# Google OAuth — https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# GitHub OAuth — https://github.com/settings/developers
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
